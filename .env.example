APP_NAME="DIY-Assist API"
ENVIRONMENT="dev"
CHROMA_PATH="./data/chroma"
CHROMA_COLLECTION="manual_chunks"
EMBED_MODEL_NAME="BAAI/bge-small-en-v1.5"
TOP_K_DEFAULT=5
PREVIOUS_STEPS_WINDOW=2
IFIXIT_API_BASE_URL="https://www.ifixit.com/api/2.0"
GUARDRAILS_ENABLED=true
RAW_DATA_DIR="./data/raw"
SLM_MODEL_NAME="qwen2.5-3b"
SLM_PROVIDER="ollama"
OLLAMA_BASE_URL="http://127.0.0.1:11434"
OLLAMA_TIMEOUT_SECONDS=60
LMSTUDIO_BASE_URL="http://127.0.0.1:1234/v1"
IFIXIT_TIMEOUT_SECONDS=30
USE_IFIXIT_LIVE_LOOKUP=true

# Stage 4: agent chat persistence + default retrieval for /api/v1/chat (naive | reranked | hyde | hyde_reranked)
CHAT_DB_PATH="./data/chat.sqlite"
CHAT_RETRIEVAL_STRATEGY="naive"
